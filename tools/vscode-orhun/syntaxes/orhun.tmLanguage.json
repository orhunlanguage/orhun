{
  "name": "Orhun",
  "scopeName": "source.orhun",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.orhun",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.orhun",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.orhun",
              "match": "\\\\."
            },
            {
              "name": "variable.interpolation.orhun",
              "match": "\\{[^}]+\\}"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.orhun",
          "match": "\\b(e휓er|ise|de휓ilse|s체rece|tekrarla|kez|deneme|yakala|k캇r|devam)\\b"
        },
        {
          "name": "keyword.declaration.orhun",
          "match": "\\b(olsun|i힊lev|d철nd체r|tip|yeni|dahil_et|d캇힊_i힊lev|dis_islev)\\b"
        },
        {
          "name": "constant.language.orhun",
          "match": "\\b(do휓ru|yanl캇힊|benim|ust|i챌in|i챌inde|sor|yazd캇r)\\b"
        },
        {
          "name": "keyword.operator.logical.orhun",
          "match": "\\b(e힊it|e힊it_de휓il|b체y체k|k체챌체k|ve|veya|de휓il)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.orhun",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.orhun",
          "match": "[+\\-*/=.:,\\[\\](){}]"
        }
      ]
    }
  }
}
