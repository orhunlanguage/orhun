işlev matris_olustur(n, d):
    satirlar olsun []
    i olsun 0
    sürece i küçük n:
        satir olsun []
        j olsun 0
        sürece j küçük n:
            listeye_ekle(satir, d)
            j = j + 1
        listeye_ekle(satirlar, satir)
        i = i + 1
    döndür satirlar

işlev matris_carp(a, b):
    n olsun uzunluk(a)
    checksum olsun 0
    i olsun 0
    sürece i küçük n:
        j olsun 0
        sürece j küçük n:
            toplam olsun 0
            k olsun 0
            sürece k küçük n:
                toplam = toplam + a[i][k] * b[k][j]
                k = k + 1
            checksum = checksum + toplam
            j = j + 1
        i = i + 1
    döndür checksum

boyut olsun 50
a olsun matris_olustur(boyut, 2)
b olsun matris_olustur(boyut, 3)
sonuc olsun matris_carp(a, b)
yazdır sonuc
