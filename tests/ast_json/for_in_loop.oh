# For-in dongusu testi (yeni satirda bloklama)
meyveler olsun ["elma", "armut", "kiraz"]
sayac olsun 0
sürece sayac küçük uzunluk(meyveler):
    yazdır meyveler[sayac]
    sayac = sayac + 1

toplam olsun 0
sayilar olsun [10, 20, 30]
i olsun 0
sürece i küçük uzunluk(sayilar):
    toplam = toplam + sayilar[i]
    i = i + 1
yazdır toplam
