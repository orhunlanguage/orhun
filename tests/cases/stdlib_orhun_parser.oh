parser olsun dahil_et "orhun/parser.oh"

kaynak olsun "işlev topla(a olsun 1, b olsun 2):\n    döndür a + b\n\nsonuc olsun topla(3)\nyazdır sonuc\n"
sonuc olsun parser.ozetle(kaynak)

yazdır parser.surum
yazdır sonuc.ok
yazdır uzunluk(sonuc.komutlar)
yazdır metin.birlestir(parser.turleri(sonuc), "|")

coklu olsun parser.ozetle("a, b olsun [1, 2]\nyazdır a\n")
yazdır metin.birlestir(parser.turleri(coklu), "|")

kontrol olsun parser.ozetle("eğer doğru ise:\n    yazdır \"evet\"\ndeğilse:\n    yazdır \"hayır\"\n")
yazdır json.yaz(kontrol.komutlar[0].blok_sayilari)
yazdır json.yaz(kontrol.komutlar[0].bloklar)

ifade_kontrol olsun parser.ozetle("yazdır a + b * 2\n")
yazdır json.yaz(ifade_kontrol.komutlar[0].ifade_ozeti)

koleksiyon_kontrol olsun parser.ozetle("liste olsun [1, 2, 3]\nyazdır [x * 2 için x içinde liste eğer x büyük 1]\n")
yazdır json.yaz(koleksiyon_kontrol.komutlar[0].ifade_ozeti.altlar)
yazdır json.yaz(koleksiyon_kontrol.komutlar[1].ifade_ozeti.altlar)

erisim_kontrol olsun parser.ozetle("ilk olsun liste[0]\nad olsun sozluk?.ad\nnesne olsun yeni Kutu(3)\n")
yazdır json.yaz(erisim_kontrol.komutlar[0].ifade_ozeti.altlar)
yazdır json.yaz(erisim_kontrol.komutlar[1].ifade_ozeti.altlar)
yazdır json.yaz(erisim_kontrol.komutlar[2].ifade_ozeti.altlar)

cagri_kontrol olsun parser.ozetle("sonuc olsun topla(4, a + 1)\nikiyle olsun işlev(x): x * 2\n")
yazdır json.yaz(cagri_kontrol.komutlar[0].ifade_ozeti)
yazdır json.yaz(cagri_kontrol.komutlar[1].ifade_ozeti)

hata olsun parser.ozetle("@\n")
yazdır hata.ok
yazdır metin.icerir(hata.hata.mesaj, "Tanimsiz")

baslik_hata olsun parser.ozetle("eğer doğru\n")
yazdır baslik_hata.ok
yazdır metin.icerir(baslik_hata.hata.mesaj, "ise")

surece_hata olsun parser.ozetle("sürece doğru\n")
yazdır surece_hata.ok
yazdır metin.icerir(surece_hata.hata.mesaj, ":")

tekrarla_hata olsun parser.ozetle("tekrarla 3\n")
yazdır tekrarla_hata.ok
yazdır metin.icerir(tekrarla_hata.hata.mesaj, "kez")

islev_hata olsun parser.ozetle("işlev ana()\n")
yazdır islev_hata.ok
yazdır metin.icerir(islev_hata.hata.mesaj, ":")

tip_hata olsun parser.ozetle("tip Kutu\n")
yazdır tip_hata.ok
yazdır metin.icerir(tip_hata.hata.mesaj, ":")

deneme_hata olsun parser.ozetle("deneme\n")
yazdır deneme_hata.ok
yazdır metin.icerir(deneme_hata.hata.mesaj, ":")
