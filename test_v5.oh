# Orhun v0.5 Testi
ayarlar olsun { proje_adi: "Yapay Zeka", parametreler: { hiz: 0.01, iterasyon: 1000 }, katmanlar: [128, 64, 10] }

yazdır "Proje: " + ayarlar.proje_adi
yazdır "Öğrenme Hızı: " + ayarlar.parametreler.hiz
yazdır "Çıkış Katmanı: " + ayarlar.katmanlar[2]

# Dinamik Erişim
anahtar olsun "iterasyon"
yazdır "Döngü Sayısı: " + ayarlar.parametreler[anahtar]
